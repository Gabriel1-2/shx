rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: anyone can read, only the wallet owner can write
    match /users/{walletAddress} {
      allow read: if true;
      allow write: if true;
    }
    // Transactions collection: anyone can read, anyone can create
    match /transactions/{txId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if false;
    }
    // System collection: health checks
    match /system/{docId} {
      allow read, write: if true;
    }
  }
}