rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: anyone can read, nobody can write from client (backend API only)
    match /users/{walletAddress} {
      allow read: if true;
      allow write: if false;
    }
    // Transactions collection: anyone can read, nobody can write from client (backend API only)
    match /transactions/{txId} {
      allow read: if true;
      allow write: if false;
    }
    // System collection: health checks
    match /system/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}