rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicitly DENY all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users: public leaderboard/stats read; writes only via Admin SDK
    match /users/{walletAddress} {
      allow read: if true;
      allow write: if false;
    }
    
    // Transactions: public activity feed; writes only via Admin SDK
    match /transactions/{txId} {
      allow read: if true;
      allow write: if false;
    }

    // Fee ledger: platform transparency (read), Admin write
    match /fee_ledger/{eventId} {
      allow read: if true;
      allow write: if false;
    }

    // Processed async orders (limit/DCA) — Admin only
    match /processed_orders/{orderId} {
      allow read, write: if false;
    }
    
    match /rate_limits/{limitId} {
      allow read, write: if false;
    }
    match /daily_snapshots/{dateId} {
      allow read, write: if false;
    }
    match /system/{docId} {
      allow read, write: if false;
    }
    match /agent_referrals/{docId} {
      allow read, write: if false;
    }
  }
}
