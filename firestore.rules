rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Explicitly DENY all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection: Public Read, Admin Write Only
    match /users/{walletAddress} {
      allow read: if true;
      allow write: if false;
    }
    
    // Transactions collection: Public Read, Admin Write Only
    match /transactions/{txId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Explicitly secure private system collections
    match /rate_limits/{limitId} {
      allow read, write: if false; // Admin backend only
    }
    match /daily_snapshots/{dateId} {
      allow read, write: if false; // Admin backend only
    }
    match /system/{docId} {
      allow read, write: if false; // Admin backend only
    }
  }
}