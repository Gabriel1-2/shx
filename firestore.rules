rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /{document=**} {
      allow read, write: if false;
    }

    // Users: public leaderboard/stats read; writes only via Admin SDK
    match /users/{walletAddress} {
      allow read: if true;
      allow write: if false;
    }
    
    match /transactions/{txId} {
      allow read: if true;
      allow write: if false;
    }

    match /fee_ledger/{eventId} {
      allow read: if true;
      allow write: if false;
    }

    // Referral code index + event feed (public read for transparency)
    match /referral_codes/{code} {
      allow read: if true;
      allow write: if false;
    }
    match /referral_events/{eventId} {
      allow read: if true;
      allow write: if false;
    }

    match /processed_orders/{orderId} {
      allow read, write: if false;
    }
    match /rate_limits/{limitId} {
      allow read, write: if false;
    }
    match /daily_snapshots/{dateId} {
      allow read, write: if false;
    }
    match /system/{docId} {
      allow read, write: if false;
    }
    match /agent_referrals/{docId} {
      allow read, write: if false;
    }
  }
}
